{
  "name": "@zico/telegram-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:tunnel": "bash scripts/devtunnel.sh",
    "dev:redis": "docker compose -f ../../docker-compose.yml up redis -d",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "webhook:set": "tsx scripts/setWebhook.ts",
    "webhook:delete": "tsx scripts/deleteWebhook.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/hydrate": "^1.6.0",
    "@grammyjs/parse-mode": "^2.3.0",
    "@grammyjs/storage-redis": "^2.5.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "grammy": "^1.29.0",
    "ioredis": "^5.4.1",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.6",
    "ioredis-mock": "^8.13.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^3.2.4"
  }
}
